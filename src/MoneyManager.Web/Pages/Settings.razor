@page "/settings"
@using MoneyManager.Web.Services.Localization
@using MoneyManager.Domain.Entities
@using MoneyManager.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@attribute [Authorize]
@inject IUserSettingsService SettingsService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IPushNotificationService PushNotificationService
@inject System.Net.Http.HttpClient Http

<PageTitle>@Localization.Get("Settings.PageTitle")</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="mb-2">
                <i class="fas fa-cog text-primary"></i> @Localization.Get("Settings.Title")
            </h1>
            <p class="text-muted">@Localization.Get("Settings.Subtitle")</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@Localization.Get("Common.Loading")</span>
            </div>
            <p class="mt-3 text-muted">@Localization.Get("Settings.Loading")</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @successMessage
                <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> @errorMessage
                <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
            </div>
        }

        <div class="row g-4">
            <!-- Prefer�ncias Financeiras -->
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-money-bill-wave"></i> @Localization.Get("Settings.FinancialPreferences")</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">@Localization.Get("Settings.Currency")</label>
                            <select class="form-select" @bind="settings.Currency">
                                <option value="BRL">@Localization.Get("Settings.CurrencyBRL")</option>
                                <option value="USD">@Localization.Get("Settings.CurrencyUSD")</option>
                                <option value="EUR">@Localization.Get("Settings.CurrencyEUR")</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localization.Get("Settings.DateFormat")</label>
                            <select class="form-select" @bind="settings.DateFormat">
                                <option value="dd/MM/yyyy">@Localization.Get("Settings.DateFormatDDMMYYYY")</option>
                                <option value="MM/dd/yyyy">@Localization.Get("Settings.DateFormatMMDDYYYY")</option>
                                <option value="yyyy-MM-dd">@Localization.Get("Settings.DateFormatYYYYMMDD")</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localization.Get("Settings.MonthClosingDay")</label>
                            <input type="number" class="form-control" min="1" max="31" @bind="settings.MonthClosingDay" />
                            <small class="text-muted">@Localization.Get("Settings.MonthClosingDayHelp")</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@Localization.Get("Settings.DefaultBudget")</label>
                            <MoneyInput @bind-Value="defaultBudgetValue" Placeholder="0,00" />
                            <small class="text-muted">@Localization.Get("Settings.DefaultBudgetHelp")</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notifica��es -->
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-bell"></i> @Localization.Get("Settings.Notifications")</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="emailNotifications" @bind="settings.EmailNotifications">
                                <label class="form-check-label" for="emailNotifications">
                                    @Localization.Get("Settings.ReceiveEmailNotifications")
                                </label>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="notifyRecurring" @bind="settings.NotifyRecurringProcessed" disabled="@(!settings.EmailNotifications)">
                                <label class="form-check-label" for="notifyRecurring">
                                    @Localization.Get("Settings.RecurringProcessed")
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="notifyBudget" @bind="settings.NotifyBudgetAlert" disabled="@(!settings.EmailNotifications)">
                                <label class="form-check-label" for="notifyBudget">
                                    @Localization.Get("Settings.BudgetAlert")
                                </label>
                            </div>
                            @if (settings.NotifyBudgetAlert && settings.EmailNotifications)
                            {
                                <div class="mt-2">
                                    <label class="form-label small">@Localization.Get("Settings.AlertWhenReaching")</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control" min="50" max="100" @bind="settings.BudgetAlertThreshold" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="notifyCreditLimit" @bind="settings.NotifyCreditLimitAlert" disabled="@(!settings.EmailNotifications)">
                                <label class="form-check-label" for="notifyCreditLimit">
                                    @Localization.Get("Settings.CreditLimitAlert")
                                </label>
                            </div>
                            @if (settings.NotifyCreditLimitAlert && settings.EmailNotifications)
                            {
                                <div class="mt-2">
                                    <label class="form-label small">@Localization.Get("Settings.AlertWhenReaching")</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control" min="50" max="100" @bind="settings.CreditLimitAlertThreshold" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="monthlySummary" @bind="settings.MonthlySummaryEmail" disabled="@(!settings.EmailNotifications)">
                                <label class="form-check-label" for="monthlySummary">
                                    @Localization.Get("Settings.MonthlySummary")
                                </label>
                            </div>
                        </div>

                        <hr />

                        <!-- Push Notifications -->
                        <div class="mb-1">
                            <h6 class="mb-1">
                                <i class="fas fa-mobile-alt me-1"></i>
                                @Localization.Get("Settings.PushNotifications")
                            </h6>
                            <small class="text-muted">@Localization.Get("Settings.PushNotificationsHelp")</small>
                        </div>

                        @if (pushPermission == "not-supported")
                        {
                            <div class="alert alert-warning py-2 mt-2 mb-0">
                                <i class="fas fa-exclamation-triangle me-1"></i>
                                @Localization.Get("Settings.PushNotSupported")
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-3 mt-2 mb-3">
                                @if (pushPermission == "granted")
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i>@Localization.Get("Settings.PushActive")
                                    </span>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="DisablePush" disabled="@isPushLoading">
                                        @if (isPushLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="fas fa-bell-slash me-1"></i>@Localization.Get("Settings.PushDisable")
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="SendTestPush" disabled="@isPushLoading">
                                        @if (isPushLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="fas fa-paper-plane me-1"></i>@Localization.Get("Settings.PushSendTest")
                                    </button>
                                }
                                else if (pushPermission == "denied")
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-ban me-1"></i>@Localization.Get("Settings.PushDenied")
                                    </span>
                                    <small class="text-muted">@Localization.Get("Settings.PushDeniedHelp")</small>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-bell-slash me-1"></i>@Localization.Get("Settings.PushInactive")
                                    </span>
                                    <button class="btn btn-sm btn-primary" @onclick="EnablePush" disabled="@isPushLoading">
                                        @if (isPushLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="fas fa-bell me-1"></i>@Localization.Get("Settings.PushEnable")
                                    </button>
                                }
                            </div>

                            @if (pushPermission == "granted")
                            {
                                <div class="mb-2">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="pushRecurring"
                                               @bind="settings.PushRecurringProcessed">
                                        <label class="form-check-label" for="pushRecurring">
                                            @Localization.Get("Settings.PushRecurringProcessed")
                                        </label>
                                    </div>
                                    <small class="text-muted ms-4">@Localization.Get("Settings.PushRecurringProcessedHelp")</small>
                                </div>

                                <div class="mb-0">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="pushDailyReminder"
                                               @bind="settings.PushDailyReminder">
                                        <label class="form-check-label" for="pushDailyReminder">
                                            @Localization.Get("Settings.PushDailyReminder")
                                        </label>
                                    </div>
                                    <small class="text-muted ms-4">@Localization.Get("Settings.PushDailyReminderHelp")</small>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Apar�ncia -->
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-palette"></i> @Localization.Get("Settings.Appearance")</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">@Localization.Get("Settings.Theme")</label>
                                <select class="form-select" @bind="settings.Theme">
                                    <option value="light">@Localization.Get("Settings.Light")</option>
                                    <option value="dark">@Localization.Get("Settings.Dark")</option>
                                    <option value="auto">@Localization.Get("Settings.Auto")</option>
                                </select>
                                <small class="text-muted">@Localization.Get("Settings.ThemeHelp")</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">@Localization.Get("Settings.PrimaryColor")</label>
                                <ColorPicker @bind-SelectedColor="settings.PrimaryColor" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bot�es de A��o -->
            <div class="col-12">
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-secondary" @onclick="LoadSettings">
                        <i class="fas fa-undo"></i> @Localization.Get("Settings.Reset")
                    </button>
                    <button class="btn btn-success" @onclick="SaveSettings" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>@Localization.Get("Settings.Saving")</span>
                        }
                        else
                        {
                            <span><i class="fas fa-save"></i> @Localization.Get("Settings.SaveSettings")</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;
    private UserSettings settings = new();
    private decimal defaultBudgetValue = 0;

    // Push notification state
    private string pushPermission = "default";
    private bool isPushLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        await LoadPushState();
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            settings = await SettingsService.GetSettingsAsync();
            defaultBudgetValue = settings.DefaultBudget ?? 0;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar configurações: {ex.Message}";
            Console.WriteLine($"Erro: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            settings.DefaultBudget = defaultBudgetValue > 0 ? defaultBudgetValue : null;
            await SettingsService.UpdateSettingsAsync(settings);

            // Apply theme
            await JSRuntime.InvokeVoidAsync("themeManager.setTheme", settings.Theme);

            successMessage = "Configurações salvas com sucesso!";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar configurações: {ex.Message}";
            Console.WriteLine($"Erro: {ex}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LoadPushState()
    {
        try
        {
            pushPermission = await PushNotificationService.GetPermissionStateAsync();
        }
        catch
        {
            pushPermission = "not-supported";
        }
    }

    private async Task EnablePush()
    {
        isPushLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await PushNotificationService.InitAsync();

            switch (result)
            {
                case "success":
                    pushPermission = "granted";
                    successMessage = Localization.Get("Settings.PushEnabledSuccess");
                    break;
                case "permission-denied":
                    pushPermission = "denied";
                    errorMessage = Localization.Get("Settings.PushPermissionDenied");
                    break;
                case "not-supported":
                    pushPermission = "not-supported";
                    errorMessage = Localization.Get("Settings.PushNotSupported");
                    break;
                default:
                    errorMessage = Localization.Get("Settings.PushEnableError");
                    break;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localization.Get("Settings.PushEnableError")}: {ex.Message}";
        }
        finally
        {
            isPushLoading = false;
        }
    }

    private async Task DisablePush()
    {
        isPushLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            await PushNotificationService.UnsubscribeAsync();
            pushPermission = "default";
            successMessage = Localization.Get("Settings.PushDisabledSuccess");
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localization.Get("Settings.PushDisableError")}: {ex.Message}";
        }
        finally
        {
            isPushLoading = false;
        }
    }

    private async Task SendTestPush()
    {
        isPushLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsync("api/push/send-test", null);
            if (response.IsSuccessStatusCode)
                successMessage = Localization.Get("Settings.PushTestSent");
            else
                errorMessage = Localization.Get("Settings.PushTestError");
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localization.Get("Settings.PushTestError")}: {ex.Message}";
        }
        finally
        {
            isPushLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !isLoading)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("themeManager.setTheme", settings.Theme);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao aplicar tema: {ex.Message}");
            }
        }
    }
}
