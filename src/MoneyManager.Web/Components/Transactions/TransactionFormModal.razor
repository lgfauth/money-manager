@using MoneyManager.Domain.Entities
@using MoneyManager.Domain.Enums
@using MoneyManager.Application.DTOs.Request
@using MoneyManager.Web.Services.Localization
@inject ILocalizationService Localization

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-plus-circle"></i> 
                        @(string.IsNullOrEmpty(EditingTransactionId) ? Localization.Get("Transactions.NewTransaction") : "Editar Transação")
                    </h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" disabled="@IsBusy"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i> @Error
                        </div>
                    }
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Data</label>
                            <input type="date" class="form-control" @bind="Request.Date" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" @bind="Request.Type">
                                <option value="0">@Localization.Get("Transactions.Income")</option>
                                <option value="1">@Localization.Get("Transactions.Expense")</option>
                                <option value="2">@Localization.Get("Transactions.Transfer")</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label">Conta @(Request.Type == 2 ? "Origem" : "")</label>
                            <select class="form-select" @bind="Request.AccountId">
                                <option value="">-- Selecione uma conta --</option>
                                @foreach (var a in GetAccountsOrdered())
                                {
                                    <option value="@a.Id">@a.Name (@GetAccountTypeLabel(a.Type))</option>
                                }
                            </select>
                        </div>
                        
                        @if (Request.Type == 2)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Conta Destino</label>
                                <select class="form-select" @bind="Request.ToAccountId">
                                    <option value="">-- Selecione a conta destino --</option>
                                    @foreach (var a in GetAccountsOrdered())
                                    {
                                        if (a.Id != Request.AccountId)
                                        {
                                            <option value="@a.Id">@a.Name (@GetAccountTypeLabel(a.Type))</option>
                                        }
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6">
                                <label class="form-label">@Localization.Get("Transactions.Category")</label>
                                <select class="form-select" @bind="Request.CategoryId">
                                    <option value="">-- Selecione uma categoria --</option>
                                    @if (CategoriesList != null)
                                    {
                                        @foreach (var c in CategoriesList)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        }
                        
                        <div class="col-12">
                            <label class="form-label">@Localization.Get("Transactions.Description")</label>
                            <input class="form-control" placeholder="Digite a descrição" @bind="Request.Description" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label">Valor</label>
                            <MoneyInput @bind-Value="Request.Amount" Placeholder="R$ 0,00" />
                        </div>

                        @if (IsSelectedAccountCreditCard() && Request.Type == 1)
                        {
                            <div class="col-12">
                                <div class="alert alert-info py-2">
                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-4">
                                            <label class="form-label mb-1">Parcelamento</label>
                                            <select class="form-select" value="@InstallmentsCount" @onchange="OnInstallmentsCountChanged">
                                                @for (var i = 1; i <= 12; i++)
                                                {
                                                    <option value="@i">@i x</option>
                                                }
                                            </select>
                                        </div>

                                        <div class="col-md-8">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="firstInCurrent" checked="@FirstInstallmentInCurrentInvoice" @onchange="OnFirstInstallmentChanged" />
                                                <label class="form-check-label" for="firstInCurrent">
                                                    Primeira parcela entra na fatura atual
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    @if (InstallmentsCount > 1)
                                    {
                                        <small class="text-muted d-block mt-2">
                                            <i class="fas fa-info-circle"></i> O valor informado é o total. O sistema lançará a 1ª parcela agora (se marcado) e criará uma recorrência mensal para as demais.
                                        </small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="OnCancel" disabled="@IsBusy">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    @if (string.IsNullOrEmpty(EditingTransactionId))
                    {
                        <button type="button" class="btn btn-primary" @onclick="() => OnSave.InvokeAsync(false)" disabled="@IsBusy">
                            <i class="fas fa-save"></i> Salvar
                        </button>
                        <button type="button" class="btn btn-success" @onclick="() => OnSave.InvokeAsync(true)" disabled="@IsBusy">
                            <i class="fas fa-plus"></i> Salvar e Adicionar Outra
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="() => OnSave.InvokeAsync(false)" disabled="@IsBusy">
                            <i class="fas fa-save"></i> Salvar Alterações
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public CreateTransactionRequestDto Request { get; set; } = default!;
    [Parameter] public string? EditingTransactionId { get; set; }
    [Parameter] public IEnumerable<Account>? AccountsList { get; set; }
    [Parameter] public IEnumerable<Category>? CategoriesList { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string? Error { get; set; }

    [Parameter] public int InstallmentsCount { get; set; } = 1;
    [Parameter] public EventCallback<int> InstallmentsCountChanged { get; set; }

    [Parameter] public bool FirstInstallmentInCurrentInvoice { get; set; } = true;
    [Parameter] public EventCallback<bool> FirstInstallmentInCurrentInvoiceChanged { get; set; }

    [Parameter] public EventCallback<bool> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsSelectedAccountCreditCard()
    {
        if (AccountsList is null) return false;
        if (string.IsNullOrWhiteSpace(Request.AccountId)) return false;

        var acc = AccountsList.FirstOrDefault(a => a.Id == Request.AccountId);
        return acc?.Type == AccountType.CreditCard;
    }

    private IEnumerable<Account> GetAccountsOrdered()
    {
        if (AccountsList is null) return Enumerable.Empty<Account>();

        return AccountsList
            .OrderBy(a => GetAccountTypeSortKey(a.Type))
            .ThenBy(a => a.Name);
    }

    private static int GetAccountTypeSortKey(AccountType type)
    {
        return type switch
        {
            AccountType.Cash => 0,
            AccountType.Checking => 1,
            AccountType.Savings => 2,
            AccountType.CreditCard => 3,
            AccountType.Investment => 4,
            _ => 99
        };
    }

    private static string GetAccountTypeLabel(AccountType type)
    {
        return type switch
        {
            AccountType.Cash => "Dinheiro",
            AccountType.Checking => "Conta Corrente",
            AccountType.Savings => "Poupança",
            AccountType.CreditCard => "Cartão de Crédito",
            AccountType.Investment => "Investimento",
            _ => type.ToString()
        };
    }

    private async Task OnInstallmentsCountChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            await InstallmentsCountChanged.InvokeAsync(val);
    }

    private async Task OnFirstInstallmentChanged(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        await FirstInstallmentInCurrentInvoiceChanged.InvokeAsync(val);
    }
}
